PORT=3002

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Encryption (node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" 로 생성)
ENCRYPTION_SECRET=your_32byte_hex_encryption_key

# NicePay (MID 방식 - 가맹점 관리자에서 확인)
NICEPAY_MID=your_merchant_id
NICEPAY_MERCHANT_KEY=your_merchant_key
# NicePay ReturnURL (결제 완료 후 NicePay가 POST로 호출하는 서버 주소 - 반드시 외부 접근 가능한 URL)
NICEPAY_RETURN_URL=https://your-server.com/api/payment/return

# AI Providers (서버 폴백용 - 사용자 키 없을 때)
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
